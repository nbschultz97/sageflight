{
  "name": "sageflight-desktop",
  "version": "0.6.0",
  "description": "Sageflight desktop app - AI-native FPV configurator & troubleshooter",
  "author": "Noah Schultz",
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "icon": "node make-icon.cjs",
    "bundle": "node build-bundle.cjs",
    "predist": "node build-bundle.cjs",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.sageflight.app",
    "productName": "Sageflight",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.cjs",
      "bundle/**/*",
      "build/icon.ico"
    ],
    "win": {
      "target": [
        "nsis",
        "dir"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "Sageflight-Setup-${version}.${ext}",
      "deleteAppDataOnUninstall": false
    }
  }
}
